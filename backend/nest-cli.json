{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "entryFile": "backend/src/main",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "../config/*.yml",
        "outDir": "./dist/config"
      },
      {
        "include": "../public/**/*.{hbs, css, js, png, jpg, jpeg, gif, svg}",
        "outDir": "./dist/public"
      }
    ],
    "plugins": [
      {
        "name": "@nestjs/swagger",
        "options": {}
      }
    ]
  }
}
