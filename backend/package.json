{
  "name": "xp-week-backend",
  "version": "1.0.1",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "cls || clear && cross-env NODE_ENV=development nest start --exec 'npm run fix:bson; node'",
    "start:watch": "cls || clear && cross-env NODE_ENV=development nest start --watch --exec 'npm run fix:bson; node'",
    "start:debug": "cls || clear && cross-env NODE_ENV=development nest start --debug --watch --exec 'npm run fix:bson; node'",
    "start:build": "cls || clear && cross-env NODE_ENV=production node dist/backend/src/main.js",
    "build": "nest build && npm run fix:bson",
    "build:watch": "nest build --watch && npm run fix:bson",
    "fix:bson": "grep -rl bson/bson . | grep dist | xargs sed -i -e 's/bson\\/bson/bson/g'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@fastify/compress": "^7.0.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/static": "^7.0.1",
    "@fastify/view": "^8.2.0",
    "@nestjs/common": "^10.3.3",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.3",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-fastify": "^10.3.3",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^5.1.2",
    "argon2": "^0.31.2",
    "bson": "^6.3.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "handlebars": "^4.7.8",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.3",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "@types/supertest": "^6.0.2",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
