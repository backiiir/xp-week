  "name": "Neighbourhood Stealth",
  "instructions": {
    "title": "Willkommen bei Neighbourhood Stealth!",
    "text": "Du bist auf einer streng geheimen Mission, um einen Gegenstand von großer Bedeutung an einen sicheren Ort zu bringen. Aber Vorsicht: gegnerische Agenten halten nach dir Ausschau. Erreiche das Ziel, ohne gesehen zu werden und ohne die Spielzone zu verlassen!",
    "btnText": "Ich bin bereit"
  },
  "propertyBag": [
    {
      "name": "lives",
      "value": 3,
      "icon": "mdi-heart"
    },
    {
      "name": "reached-destination",
      "value": false,
      "icon": null
    }
  ],
  "gameConditions": [
    {
      "type": "win",
      "condition": {
        "accessor": "propertyBag",
        "key": "reached-destination",
        "value": true,
        "operator": "equals"
      },
      "events": [
        {
          "eventType": "popup",
          "title": "Mission erfolgreich!",
          "text": "Du hast das Ziel erreicht, ohne entdeckt zu werden! Herzlichen Glückwunsch!",
          "btnText": "Zurück zum Menü",
          "nextEvent": {
            "eventType": "backToMenu",
            "nextEvent": null
          }
        }
      ]
    },
    {
      "type": "lose",
      "condition": {
        "accessor": "propertyBag",
        "key": "lives",
        "value": 0,
        "operator": "equals"
      },
      "events": [
        {
          "eventType": "popup",
          "title": "Game over!",
          "text": "Du hast es nicht geschafft. Versuch es noch einmal!",
          "btnText": "Zurück zum Menü",
          "nextEvent": {
            "eventType": "backToMenu",
            "nextEvent": null
          }
        }
      ]
    }
  ],
