{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "moduleResolution": "Node16",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "importHelpers": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true
  }
}
