{
  "name": "xp-week-frontend",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start:watch": "vite",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build": "vite build",
    "type-check": "vue-tsc --build --force",
    "mobile:sync:android": "pnpm build && cap sync android && cap update android && cap copy android",
    "mobile:open:android": "cap open android",
    "mobile:sync:ios": "pnpm build && cap sync ios && cap update ios && cap copy ios",
    "mobile:open:ios": "cap open ios",
    "mobile:gensplash": "capacitor-assets generate --ios --android"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/device": "^6.0.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/screen-orientation": "^6.0.0",
    "@turf/turf": "^6.5.0",
    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "capacitor-plugin-safe-area": "^2.0.6",
    "common": "workspace:xp-week-common@*",
    "material-icons": "^1.13.12",
    "pinia": "^2.1.7",
    "vue": "^3.4.22",
    "vue-router": "^4.3.0",
    "vuelidate": "^0.7.7",
    "vuetify": "^3.5.15"
