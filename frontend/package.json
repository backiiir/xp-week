    "@types/leaflet": "^1.9.11",
    "@types/node": "^20.12.7",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "@vue-leaflet/vue-leaflet": "^0.10.1",
    "@vue/test-utils": "^2.4.5",
    "@vue/tsconfig": "^0.5.1",
    "jsdom": "^24.0.0",
    "leaflet": "^1.9.4",
    "material-design-icons-iconfont": "^6.7.0",
    "npm-run-all2": "^6.1.2",
    "typescript": "~5.4.5",
